# Local backend configuration. Keep real secrets only in this ignored file.
# Values already present in the process environment take precedence.

# LLM
LLM_PROVIDER=llm
LLM_API_BASE_URL=
LLM_API_PATH=/chat/completions
LLM_MODEL=
LLM_API_KEY=
MINIMAX_API_KEY=

# Agent runtime
AGENT_ENABLE_WEB_SEARCH=1
SUBAGENT_CONTRACTS_DIR=

# Web Search orchestration
SEARCH_PRIMARY_PROVIDER=baidu_qianfan
SEARCH_FALLBACK_PROVIDER=firecrawl
SEARCH_HIGH_RISK_DUAL_PROVIDER=1
SEARCH_TIMEOUT_SECONDS=8
SEARCH_MAX_RESULTS=8
SEARCH_ENABLE_FALLBACK=1
SEARCH_TRUSTED_DOMAINS=

# Baidu Qianfan REST Web Search
BAIDU_QIANFAN_API_KEY=
BAIDU_QIANFAN_SEARCH_ENDPOINT=https://qianfan.baidubce.com/v2/ai_search/web_search

# Firecrawl REST Search and Scrape
FIRECRAWL_API_KEY=
FIRECRAWL_SEARCH_ENDPOINT=https://api.firecrawl.dev/v2/search
FIRECRAWL_SCRAPE_ENDPOINT=https://api.firecrawl.dev/v2/scrape

# Manual live acceptance tests
RUN_LIVE_SEARCH_TESTS=0
